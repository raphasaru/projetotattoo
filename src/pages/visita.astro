---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import Transformation from '../components/Transformation.astro';
import SocialProof from '../components/SocialProof.astro';
import Method from '../components/Method.astro';
import Testimonials from '../components/Testimonials.astro';
import Portfolio from '../components/Portfolio.astro';
import Investment from '../components/Investment.astro';
import Included from '../components/Included.astro';
import Objections from '../components/Objections.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTAVisita from '../components/FinalCTAVisita.astro';

const ctaHref = "#agendar";
---

<Layout title="Visite a Escola de Tatuagem | Conheça o Projeto Tattoo em Santana">
  <main>
    <Hero ctaHref={ctaHref} ctaText="Agendar minha visita à escola" ctaExternal={false} />
    <PainPoints />
    <Transformation ctaHref={ctaHref} />
    <SocialProof />
    <Method ctaHref={ctaHref} />
    <Testimonials />
    <Portfolio />
    <Investment ctaHref={ctaHref} />
    <Included />
    <Objections />
    <FAQ />
    <FinalCTAVisita />
  </main>

  <footer class="footer">
    <div class="footer-container">
      <div class="footer-brand">
        <img src="/images/projeto-tattoo-logo-dourado.webp" alt="Projeto Tattoo" class="footer-logo" width="160" height="160" />
        <span class="brand-tagline">13 anos formando tatuadores profissionais</span>
      </div>

      <div class="footer-links">
        <a href="https://instagram.com/projetotattoo" target="_blank" rel="noopener" class="social-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="18" cy="6" r="1" fill="currentColor"/>
          </svg>
          <span>Instagram</span>
        </a>
        <a href="https://youtube.com/@projetotattoo" target="_blank" rel="noopener" class="social-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/>
          </svg>
          <span>YouTube</span>
        </a>
        <a href="https://api.whatsapp.com/send?phone=5511941721536&text=Vim%20do%20site%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es" target="_blank" rel="noopener" class="footer-whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

      <div class="footer-legal">
        <p>R. Alferes Magalhães, 92 - Sala 137 - Santana, São Paulo - SP, 02034-006</p>
        <p>&copy; {new Date().getFullYear()} Projeto Tattoo. Todos os direitos reservados.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  main {
    overflow-x: hidden;
  }

  .footer {
    background: var(--black);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 3rem 0;
  }

  .footer-container {
    width: min(90%, 1200px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-logo {
    width: 160px;
    height: auto;
  }

  .brand-tagline {
    font-size: 0.85rem;
    color: var(--white-dim);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--white-dim);
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .social-link:hover {
    color: var(--gold);
  }

  .social-link svg {
    width: 20px;
    height: 20px;
  }

  .footer-whatsapp {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    background: #25D366;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 20px;
    transition: background 0.2s, transform 0.15s;
  }

  .footer-whatsapp:hover {
    background: #1ebe5d;
    transform: translateY(-1px);
  }

  .footer-legal {
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    width: 100%;
  }

  .footer-legal p {
    font-size: 0.8rem;
    color: var(--white-dim);
    opacity: 0.5;
  }
</style>

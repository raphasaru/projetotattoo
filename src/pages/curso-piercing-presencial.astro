---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout
  title="Curso de Piercing Presencial | Projeto Tattoo"
  description="Aprenda a arte do body piercing na prática com aulas 100% presencial. Curso de 7 horas com teoria, prática, materiais e certificado."
>
  <main>

    <!-- HERO -->
    <section class="hero-piercing" id="topo">
      <div class="hero-glow"></div>
      <div class="container hero-grid">
        <div class="hero-text">
          <img src="/piercing/logo.webp" alt="Projeto Tattoo" class="hero-logo" width="140" />

          <span class="badge">
            <span class="badge-dot"></span>
            Curso 100% Presencial
          </span>

          <h1>
            CURSO DE<br/>
            <span class="accent">PIERCING</span><br/>
            PRESENCIAL
          </h1>

          <p class="hero-sub">
            Aprenda a arte do body piercing na prática com aulas 100% presencial.<br/>
            Da bancada às joias — técnicas, biossegurança e ética profissional em um único curso intensivo.
          </p>

          <a
            href="https://api.whatsapp.com/send?phone=5511941721536&text=Gostaria%20de%20ter%20informa%C3%A7%C3%B5es%20sobre%20o%20curso%20de%20Piercing"
            target="_blank"
            rel="noopener"
            class="btn-whatsapp"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            QUERO SABER MAIS
          </a>
        </div>

        <div class="hero-image-wrap">
          <div class="hero-frame">
            <img src="/piercing/hero.webp" alt="Curso de Piercing Presencial" class="hero-img" />
          </div>
          <div class="hero-stat">
            <span class="stat-num">+12</span>
            <span class="stat-label">anos formando profissionais</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PRA QUEM -->
    <section class="section pra-quem">
      <div class="container">
        <div class="section-label">público</div>
        <h2>PRA QUEM É<br/><span class="accent">O CURSO?</span></h2>
        <div class="quem-grid">
          <div class="quem-card">
            <div class="quem-num">01</div>
            <h3>Tatuadores Profissionais</h3>
            <p>Que desejam expandir seus serviços e oferecer mais aos clientes.</p>
          </div>
          <div class="quem-card">
            <div class="quem-num">02</div>
            <h3>Profissionais de Beleza</h3>
            <p>Que buscam diversificar seus serviços e atender a uma demanda crescente.</p>
          </div>
          <div class="quem-card">
            <div class="quem-num">03</div>
            <h3>Iniciantes na Arte</h3>
            <p>Pessoas com paixão pela arte corporal que querem começar uma carreira como piercer.</p>
          </div>
          <div class="quem-card">
            <div class="quem-num">04</div>
            <h3>Empreendedores</h3>
            <p>Que veem oportunidade no mundo do piercing e desejam investir com conhecimento.</p>
          </div>
        </div>
        <div class="cta-center">
          <a href="https://api.whatsapp.com/send?phone=5511941721536&text=Gostaria%20de%20ter%20informa%C3%A7%C3%B5es%20sobre%20o%20curso%20de%20Piercing" target="_blank" rel="noopener" class="btn-gold">QUERO ME INSCREVER</a>
        </div>
      </div>
    </section>

    <!-- O QUE VAI APRENDER -->
    <section class="section aprender">
      <div class="container">
        <div class="section-label">conteúdo</div>
        <h2>O QUE VOCÊ VAI<br/><span class="accent">APRENDER</span></h2>
        <div class="aprender-grid">
          <div class="aprender-card">
            <img src="/piercing/icon-materiais.webp" alt="Materiais" class="aprender-icon" />
            <h3>Materiais e Equipamentos</h3>
            <p>Da bancada à escolha das joias e cateteres. Conheça os diferentes tipos, materiais e a melhor aplicação para cada um.</p>
          </div>
          <div class="aprender-card">
            <img src="/piercing/icon-demarcacoes.webp" alt="Demarcações" class="aprender-icon" />
            <h3>Demarcações</h3>
            <p>Aprenda a demarcar corretamente. Domine técnicas e métodos para realizar piercings com precisão e segurança.</p>
          </div>
          <div class="aprender-card">
            <img src="/piercing/icon-aplicacao.webp" alt="Aplicação" class="aprender-icon" />
            <h3>Aplicação na Prática</h3>
            <p>Treino em material sintético e pele humana com voluntário, com orientação e supervisão direta do professor.</p>
          </div>
          <div class="aprender-card">
            <img src="/piercing/icon-biosseguranca.webp" alt="Biossegurança" class="aprender-icon" />
            <h3>Biossegurança</h3>
            <p>Tudo sobre EPIs, esterilização e prevenção de acidentes. Como preparar a área e orientar clientes nos cuidados pós-procedimento.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRESENCIAL DESTAQUE -->
    <section class="section presencial-banner">
      <div class="container">
        <div class="banner-inner">
          <div class="banner-text">
            <div class="section-label">formato</div>
            <h2>100%<br/><span class="accent">PRESENCIAL</span></h2>
            <p>
              O Curso de Body Piercing é totalmente presencial, permitindo uma experiência de aprendizado imersiva.
              Aqui você não apenas ouvirá e verá — você praticará, sob orientação direta do professor.
            </p>
            <p>
              O formato presencial garante feedback imediato, dúvidas esclarecidas no momento e habilidades práticas
              desenvolvidas em ambiente seguro. Venha vivenciar, aprender e crescer conosco no Projeto Tattoo!
            </p>
            <a href="https://api.whatsapp.com/send?phone=5511941721536&text=Gostaria%20de%20ter%20informa%C3%A7%C3%B5es%20sobre%20o%20curso%20de%20Piercing" target="_blank" rel="noopener" class="btn-gold">QUERO SABER MAIS</a>
          </div>
          <div class="banner-nums">
            <div class="big-num">
              <span class="num">2</span>
              <span class="num-label">dias de curso</span>
            </div>
            <div class="num-divider"></div>
            <div class="big-num">
              <span class="num">7<span class="num-unit">h</span></span>
              <span class="num-label">de duração total</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- INCLUSÕES -->
    <section class="section inclusoes" id="inclusoes">
      <div class="container">
        <div class="section-label">o que está incluso</div>
        <h2>TUDO QUE VOCÊ<br/><span class="accent">RECEBE</span></h2>
        <div class="inclusoes-grid">
          <div class="inc-card">
            <div class="inc-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><line x1="12" y1="12" x2="12" y2="12"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
            </div>
            <h3>Materiais da Aula</h3>
            <p>Todo o material necessário durante o curso é providenciado pela escola para uso nas aulas.</p>
          </div>
          <div class="inc-card">
            <div class="inc-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <h3>Apostila Completa</h3>
            <p>Apostila com todos os conteúdos do curso para acompanhar as aulas e consultar depois.</p>
          </div>
          <div class="inc-card">
            <div class="inc-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3>Aula 100% Presencial</h3>
            <p>2 dias de curso presencial com duração de 7 horas. Inclui sessões práticas supervisionadas.</p>
          </div>
          <div class="inc-card">
            <div class="inc-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <h3>Certificado</h3>
            <p>Ao final, você recebe um certificado reconhecendo sua competência como Body Piercer.</p>
          </div>
        </div>
        <div class="cta-center">
          <a href="https://api.whatsapp.com/send?phone=5511941721536&text=Gostaria%20de%20ter%20informa%C3%A7%C3%B5es%20sobre%20o%20curso%20de%20Piercing" target="_blank" rel="noopener" class="btn-gold">QUERO ME INSCREVER</a>
        </div>
      </div>
    </section>

    <!-- SOBRE A ESCOLA -->
    <section class="section sobre">
      <div class="container sobre-grid">
        <div class="sobre-text">
          <div class="section-label">quem somos</div>
          <h2>SOBRE A<br/><span class="accent">PROJETO TATTOO</span></h2>
          <p>
            Fundada em 2013 pelo Tatuador e Professor <strong>Régis Silva</strong>, a Projeto Tattoo rapidamente
            se estabeleceu como uma das principais escolas de tatuagem do país.
          </p>
          <p>
            Com uma paixão inabalável pela arte corporal e um compromisso com a excelência educacional,
            temos orgulho de escrever um novo capítulo em nossa história com o Curso Presencial de Piercing.
          </p>
          <div class="contact-list">
            <div class="contact-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>(11) 2208-8534</span>
            </div>
            <div class="contact-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>(11) 94172-1536</span>
            </div>
            <div class="contact-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Rua Alferes Magalhães, 92 — 8º Andar, Santana, SP</span>
            </div>
          </div>
          <a href="https://api.whatsapp.com/send?phone=5511941721536&text=Gostaria%20de%20ter%20informa%C3%A7%C3%B5es%20sobre%20o%20curso%20de%20Piercing" target="_blank" rel="noopener" class="btn-gold">FALAR COM A EQUIPE</a>
        </div>
        <div class="sobre-image-wrap">
          <img src="/piercing/escola.webp" alt="Projeto Tattoo" class="sobre-img" />
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-container">
      <img src="/images/projeto-tattoo-logo-dourado.webp" alt="Projeto Tattoo" class="footer-logo" width="140" />
      <p class="footer-text">Projeto Tattoo LTDA — CNPJ: 21.101.300/0001-37</p>
      <p class="footer-text">© {new Date().getFullYear()} Todos os direitos reservados.</p>
    </div>
  </footer>

  <WhatsAppButton />
</Layout>

<style>
  /* ── HERO ── */
  .hero-piercing {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
    overflow: hidden;
    background: var(--black);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(201,169,98,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    width: min(90%, 1200px);
    margin: 0 auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-logo {
    width: 120px;
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(201,169,98,0.4);
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.8rem;
    font-family: var(--font-body);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
    color: var(--white);
  }

  .accent { color: var(--gold); }

  .hero-sub {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--white-dim);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  /* WhatsApp CTA button */
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 1rem 2rem;
    background: #25D366;
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 0 28px rgba(37,211,102,0.35);
  }

  .btn-whatsapp:hover {
    background: #1ebe5d;
    transform: translateY(-2px);
  }

  /* Hero image */
  .hero-image-wrap {
    position: relative;
  }

  .hero-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(201,169,98,0.2);
  }

  .hero-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.5) 0%, transparent 50%);
    z-index: 1;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-stat {
    position: absolute;
    bottom: -1.5rem;
    left: -1.5rem;
    background: var(--gold);
    color: var(--black);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
    text-align: center;
  }

  /* ── SHARED SECTION STYLES ── */
  .section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-label {
    font-size: 0.75rem;
    font-family: var(--font-body);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }

  .cta-center {
    text-align: center;
    margin-top: 3rem;
  }

  .btn-gold {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    border-radius: 6px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }

  /* ── PRA QUEM ── */
  .pra-quem {
    background: var(--black-light);
  }

  .quem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .quem-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 2rem;
    transition: border-color 0.3s;
  }

  .quem-card:hover { border-color: rgba(201,169,98,0.3); }

  .quem-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--gold);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .quem-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
  }

  .quem-card p {
    font-size: 0.95rem;
    color: var(--white-dim);
    line-height: 1.6;
  }

  /* ── APRENDER ── */
  .aprender {
    background: var(--black);
  }

  .aprender-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .aprender-card {
    background: var(--black-lighter);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color 0.3s, transform 0.2s;
  }

  .aprender-card:hover {
    border-color: rgba(201,169,98,0.3);
    transform: translateY(-4px);
  }

  .aprender-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.25rem;
    object-fit: contain;
  }

  .aprender-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.03em;
    margin-bottom: 0.75rem;
    color: var(--gold);
  }

  .aprender-card p {
    font-size: 0.9rem;
    color: var(--white-dim);
    line-height: 1.6;
  }

  /* ── PRESENCIAL BANNER ── */
  .presencial-banner {
    background: linear-gradient(135deg, var(--black-light) 0%, #0f0f0f 100%);
    border-top: 1px solid rgba(201,169,98,0.15);
    border-bottom: 1px solid rgba(201,169,98,0.15);
  }

  .banner-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .banner-text h2 { margin-bottom: 1.5rem; }

  .banner-text p {
    font-size: 1rem;
    color: var(--white-dim);
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 560px;
  }

  .banner-text .btn-gold { margin-top: 1rem; }

  .banner-nums {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    min-width: 180px;
  }

  .big-num {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .num {
    font-family: var(--font-display);
    font-size: 6rem;
    line-height: 1;
    color: var(--gold);
  }

  .num-unit {
    font-size: 3rem;
  }

  .num-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white-dim);
  }

  .num-divider {
    width: 1px;
    height: 40px;
    background: rgba(201,169,98,0.3);
  }

  /* ── INCLUSÕES ── */
  .inclusoes {
    background: var(--black);
  }

  .inclusoes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }


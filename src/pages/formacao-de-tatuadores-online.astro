---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const modules = [
  { icon: '/formacao/icon-maquinas.png', title: 'Máquinas e Equipamentos', body: 'As principais marcas, modelos e configurações. Como escolher a máquina perfeita para você sem estourar o orçamento.' },
  { icon: '/formacao/icon-tintas.png', title: 'Tintas e Pigmentos', body: 'Principais marcas, diluição correta e características de cada cor para criar tatuagens vibrantes.' },
  { icon: '/formacao/icon-agulhas.png', title: 'Agulhas', body: 'Formatos, tamanhos, agrupamentos e tipos de pontas. Como escolher a agulha certa para cada estilo.' },
  { icon: '/formacao/icon-tecnicas.png', title: 'Técnicas', body: 'Traço, preenchimento sólido, degradê de sombra e colorido. Os segredos de cada técnica para um acabamento profissional.' },
  { icon: '/formacao/icon-biosseguranca.png', title: 'Biossegurança', body: 'Higiene, EPIs, descarte correto de materiais e prevenção de contaminações.' },
  { icon: '/formacao/icon-estencil.png', title: 'Estêncil', body: 'Técnicas e dicas para criar estênceis precisos, garantindo que o design seja transferido com perfeição.' },
  { icon: '/formacao/icon-marketing.webp', title: 'Marketing e Empreendedorismo', body: 'Módulo bônus: como divulgar seu trabalho, precificar suas tatuagens e prospectar clientes.' },
];

const bonuses = [
  { label: 'BÔNUS 1', img: '/formacao/bonus-master.webp', type: 'Curso Online em Vídeo', title: 'Criação de Desenho para Tatuagem', body: 'No curso Master Lessons, você aprenderá a desenhar e criar artes com foco na tatuagem. 12 módulos com os estilos mais pedidos.' },
  { label: 'BÔNUS 2', img: '/formacao/bonus-fineline.webp', type: 'Curso Online em Vídeo', title: 'Tattoo Fine Line', body: 'Técnicas avançadas de tatuagem de linha fina para criar tatuagens delicadas e precisas que impressionam.' },
  { label: 'BÔNUS 3', img: '/formacao/bonus-desconto.jpg', type: 'Voucher', title: 'Desconto no Curso Presencial', body: 'Ganhe um voucher de R$ 600 para usar como desconto no curso presencial de tatuagem em nossa escola em São Paulo.' },
];

const faqs = [
  { q: 'O curso é online ou presencial?', a: 'O curso é 100% online, hospedado na plataforma Kiwify. Você pode assistir de qualquer computador ou smartphone com internet, de qualquer parte do mundo.' },
  { q: 'As aulas são gravadas?', a: 'Sim, com excelente qualidade de imagem e som. Você pode assistir no seu ritmo, pausar e continuar quando quiser.' },
  { q: 'Quem é o professor?', a: 'O curso é apresentado pelo professor Régis Silva, tatuador há 20 anos que atende no Brasil e na Inglaterra, e fundador da Escola Projeto Tattoo.' },
  { q: 'Preciso saber desenhar?', a: 'Não. A tatuagem é um trabalho de ilustração na pele — o mais importante é aprender as técnicas corretas de aplicação. Desenhar ajuda, mas não é imprescindível.' },
  { q: 'Por quanto tempo o curso fica disponível?', a: 'O curso fica disponível por 1 (um) ano a partir da data da compra, com acesso ilimitado.' },
  { q: 'E se eu não ficar satisfeito?', a: 'Você tem garantia incondicional de 7 dias. Se não ficar satisfeito por qualquer motivo, basta solicitar cancelamento e você recebe o reembolso integral.' },
];
---

<Layout
  title="Formação de Tatuadores Online | Projeto Tattoo"
  description="Aprenda a tatuar do zero e torne-se um tatuador profissional. Curso 100% online com aulas gravadas, metodologia aprovada por mais de 4 mil alunos."
>
  <main>

    <!-- HERO -->
    <section class="hero-online" id="topo">
      <div class="hero-glow-1"></div>
      <div class="hero-glow-2"></div>
      <div class="container hero-grid">
        <div class="hero-text">
          <img src="/formacao/logo.webp" alt="Projeto Tattoo" class="hero-logo" width="140" />

          <span class="badge">
            <span class="badge-dot"></span>
            +4.000 alunos formados
          </span>

          <h1>
            FORMAÇÃO DE<br/>
            <span class="accent">TATUADORES</span><br/>
            PROFISSIONAL ONLINE
          </h1>

          <p class="hero-sub">
            Aprenda a tatuar do zero e torne-se um tatuador profissional em pouco tempo.
            Curso 100% online com aulas gravadas — veja quando e onde quiser.
          </p>

          <div class="trust-strip">
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Mesma metodologia do curso presencial
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Acesso por 1 ano
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Garantia de 7 dias
            </div>
          </div>

          <a href="#preco" class="btn-primary">
            QUERO SER UM(A) TATUADOR(A)
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="hero-visual">
          <div class="hero-frame">
            <img src="/formacao/professor.png" alt="Professor Régis Silva" class="hero-img" />
            <div class="hero-badge-float">
              <span class="hbf-num">+4.000</span>
              <span class="hbf-label">alunos formados</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRA QUEM -->
    <section class="section pra-quem">
      <div class="container pq-grid">
        <div class="pq-text">
          <div class="section-label">público</div>
          <h2>PRA QUEM É<br/><span class="accent">O CURSO?</span></h2>
          <p>O Formação de Tatuadores é perfeito para qualquer pessoa que tenha o sonho de se tornar um tatuador profissional e que ama arte — independentemente de saber ou não desenhar.</p>
          <div class="pq-items">
            <div class="pq-item">
              <div class="pq-dot"></div>
              <div>
                <strong>DO ZERO</strong>
                <p>Quem vai começar do absoluto zero e nunca ligou uma máquina de tatuagem antes.</p>
              </div>
            </div>
            <div class="pq-item">
              <div class="pq-dot"></div>
              <div>
                <strong>INICIANTE</strong>
                <p>Quem já começou sozinho assistindo vídeos, mas não está vendo evolução nos trabalhos.</p>
              </div>
            </div>
          </div>
          <a href="#preco" class="btn-primary">QUERO SER UM(A) TATUADOR(A)</a>
        </div>
        <div class="pq-image">
          <img src="/formacao/hero.png" alt="Formação de Tatuadores" />
        </div>
      </div>
    </section>

    <!-- MÓDULOS -->
    <section class="section modulos">
      <div class="container">
        <div class="section-label">conteúdo</div>
        <h2>O QUE VOCÊ VAI<br/><span class="accent">APRENDER</span></h2>
        <div class="modulos-grid">
          {modules.map((m, i) => (
            <div class="modulo-card">
              <div class="modulo-header">
                <img src={m.icon} alt={m.title} class="modulo-icon" />
                <span class="modulo-num">0{i+1}</span>
              </div>
              <h3>{m.title}</h3>
              <p>{m.body}</p>
            </div>
          ))}
        </div>
        <div class="cta-center">
          <a href="#preco" class="btn-primary">QUERO ME INSCREVER</a>
        </div>
      </div>
    </section>

    <!-- VIDEO INSIDE -->
    <section class="section video-section">
      <div class="container">
        <div class="section-label">preview</div>
        <h2>POR DENTRO<br/><span class="accent">DO CURSO</span></h2>
        <p class="video-sub">Veja um pouco do que você terá acesso ao se inscrever no Formação de Tatuadores Profissional Online</p>
        <div class="video-wrapper">
          <iframe
            src="https://player.vimeo.com/video/775087562"
            title="Por Dentro do Curso"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <!-- BÔNUS -->
    <section class="section bonus" id="bonus">
      <div class="container">
        <div class="section-label">extras</div>
        <h2>NOSSOS<br/><span class="accent">BÔNUS</span></h2>
        <p class="bonus-sub">Cursos bônus que vão te ajudar a evoluir e aprimorar suas habilidades</p>
        <div class="bonus-grid">
          {bonuses.map(b => (
            <div class="bonus-card">
              <div class="bonus-img-wrap">
                <span class="bonus-label-badge">{b.label}</span>
                <img src={b.img} alt={b.title} />
              </div>
              <div class="bonus-content">
                <span class="bonus-type">{b.type}</span>
                <h3>{b.title}</h3>
                <p>{b.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMUNIDADE -->
    <section class="section comunidade">
      <div class="container">
        <div class="section-label">suporte</div>
        <h2>COMUNIDADE DE<br/><span class="accent">APRENDIZADO</span></h2>
        <p class="com-sub">Mesmo estudando em casa, você nunca estará sozinho.</p>
        <div class="com-grid">
          <div class="com-card">
            <img src="/formacao/icon-whatsapp.webp" alt="WhatsApp" class="com-icon" />
            <h3>Comunidade no WhatsApp</h3>
            <p>Faça parte de uma comunidade exclusiva de alunos da escola.</p>
          </div>
          <div class="com-card">
            <img src="/formacao/icon-live.webp" alt="Live Mensal" class="com-icon" />
            <h3>Live Mensal com Professor</h3>
            <p>Todos os meses tem uma live ao vivo com um dos professores do Projeto Tattoo.</p>
          </div>
          <div class="com-card">
            <img src="/formacao/icon-suporte.webp" alt="Suporte" class="com-icon" />
            <h3>Suporte ao Aluno</h3>
            <p>Canal de acesso via WhatsApp para tirar dúvidas diretamente com a equipe.</p>
          </div>
        </div>
        <div class="cta-center">
          <a href="#preco" class="btn-primary">QUERO ME INSCREVER</a>
        </div>
      </div>
    </section>

    <!-- PREÇO -->
    <section class="section preco-section" id="preco">
      <div class="container">
        <div class="section-label">investimento</div>
        <h2>VALOR DO<br/><span class="accent">INVESTIMENTO</span></h2>
        <p class="preco-sub">Faça já sua matrícula e comece ainda hoje uma nova jornada profissional</p>

        <div class="preco-grid">
          <div class="preco-card">
            <div class="preco-tag">Promoção por tempo limitado</div>
            <h3 class="preco-title">FORMAÇÃO DE TATUADORES ONLINE</h3>

            <div class="preco-valor">
              <span class="preco-parcelado">12x <strong>R$ 64,95</strong></span>
              <span class="preco-ou">ou</span>
              <span class="preco-vista">R$ 628,00 à vista</span>
            </div>

            <ul class="preco-lista">
              <li><span class="check">★</span> Curso de Tatuagem Online Completo</li>
              <li><span class="check">★</span> Certificado</li>
              <li><span class="check">★</span> Curso Master Lessons (Criação de Desenho)</li>
              <li><span class="check">★</span> Curso Fine Line</li>
              <li><span class="check">★</span> Módulo Bônus Marketing e Empreendedorismo</li>
              <li><span class="check">★</span> Comunidade de Alunos no WhatsApp</li>
              <li><span class="check">★</span> Live Mensal com Professores</li>
              <li><span class="check">★</span> Suporte via WhatsApp</li>
            </ul>

            <a href="https://pay.kiwify.com.br/i7DqFlZ" target="_blank" rel="noopener" class="btn-comprar">
              QUERO SER UM(A) TATUADOR(A)
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="garantia-card">
            <img src="/formacao/garantia.png" alt="Garantia 7 dias" class="garantia-img" />
            <h3>Garantia Incondicional de 7 Dias</h3>
            <p>Se por qualquer motivo dentro desse prazo você não ficar satisfeito, basta solicitar o cancelamento e você terá o <strong>reembolso integral</strong> do valor investido.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq-section">
      <div class="container faq-container">
        <div class="section-label">dúvidas</div>
        <h2>PERGUNTAS<br/><span class="accent">FREQUENTES</span></h2>
        <div class="faq-grid">
          {faqs.map(f => (
            <div class="faq-item">
              <h4>{f.q}</h4>
              <p>{f.a}</p>
            </div>
          ))}
        </div>

        <div class="faq-contato">
          <h3>Ficou alguma dúvida?</h3>
          <p>Fale com a gente nos canais oficiais do Projeto Tattoo</p>
          <div class="contato-links">
            <a href="https://www.instagram.com/projetotattoo/" target="_blank" rel="noopener" class="contato-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1" fill="currentColor"/></svg>
              Instagram
            </a>
            <a href="https://api.whatsapp.com/send?phone=5511941721536" target="_blank" rel="noopener" class="contato-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SOBRE A ESCOLA -->
    <section class="section sobre-escola">
      <div class="container">
        <div class="section-label">quem somos</div>
        <h2>A <span class="accent">PROJETO TATTOO</span></h2>
        <div class="escola-grid">
          <div class="escola-text">
            <p>
              O Projeto Tattoo é a <strong>primeira escola de tatuagem a ministrar cursos online no Brasil.</strong>
              Fundado em 2013 por Régis Silva, já formou milhares de alunos inclusive em outros países como
              Japão, Inglaterra, Portugal, Suíça, França, Espanha, Colômbia e Estados Unidos.
            </p>
            <div class="nums-strip">
              <div class="escola-num">
                <span class="en-val">+160.000</span>
                <span class="en-label">seguidores nas redes sociais</span>
              </div>
              <div class="escola-num-div"></div>
              <div class="escola-num">
                <span class="en-val">+4.000</span>
                <span class="en-label">alunos formados em 10 anos</span>
              </div>
            </div>
            <a href="#preco" class="btn-primary">QUERO ME INSCREVER</a>
          </div>
          <div class="escola-video">
            <div class="video-frame">
              <iframe
                src="https://www.youtube.com/embed/fi7De_SUjQs?start=2"
                title="Projeto Tattoo no Mundo Empresarial"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-container">
      <img src="/images/projeto-tattoo-logo-dourado.webp" alt="Projeto Tattoo" class="footer-logo" width="140" />
      <p class="footer-text">Projeto Tattoo LTDA — CNPJ: 21.101.300/0001-37</p>
      <p class="footer-text">R. Alferes Magalhães, 92 - Sala 137 - Santana, São Paulo - SP, 02034-006</p>
      <p class="footer-text">© {new Date().getFullYear()} Todos os direitos reservados.</p>
    </div>
  </footer>

  <WhatsAppButton />
</Layout>

<style>
  /* ── HERO ── */
  .hero-online {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
    overflow: hidden;
    background: var(--black);
  }

  .hero-glow-1 {
    position: absolute;
    top: -20%;
    right: -5%;
    width: 55vw;
    height: 55vw;
    background: radial-gradient(circle, rgba(201,169,98,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, rgba(34,197,94,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    width: min(90%, 1200px);
    margin: 0 auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-logo {
    width: 120px;
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(201,169,98,0.4);
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
    color: var(--white);
  }

  .accent { color: var(--gold); }

  .hero-sub {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    color: var(--white-dim);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 480px;
  }

  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--white-dim);
  }

  .trust-item svg { color: var(--green); flex-shrink: 0; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }

  .hero-visual { position: relative; }

  .hero-frame {
    position: relative;
    border-radius: 16px;
    overflow: visible;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
    border: 1px solid rgba(201,169,98,0.15);
  }

  .hero-badge-float {
    position: absolute;
    bottom: 2rem;
    left: -2rem;
    background: var(--gold);
    color: var(--black);
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hbf-num {
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .hbf-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
    white-space: nowrap;
  }

  /* ── SHARED ── */
  .section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }

  .cta-center {
    text-align: center;
    margin-top: 3rem;
  }

  /* ── PRA QUEM ── */
  .pra-quem { background: var(--black-light); }

  .pq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .pq-text h2 { margin-bottom: 1rem; }

  .pq-text > p {
    font-size: 1rem;
    color: var(--white-dim);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .pq-items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .pq-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .pq-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
    margin-top: 5px;
  }

  .pq-item strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
    color: var(--gold);
  }

  .pq-item p {
    font-size: 0.9rem;
    color: var(--white-dim);
    margin: 0;
    line-height: 1.6;
  }

  .pq-image img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(201,169,98,0.15);
  }

  /* ── MÓDULOS ── */
  .modulos { background: var(--black); }

  .modulos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);

---
import Layout from '../layouts/Layout.astro';

const links = [
  {
    label: "Curso Presencial de Tatuagem",
    sub: "40h de imersão · 2 tatuagens reais",
    href: "/curso-tatuagem-presencial",
    icon: "needle",
    highlight: true,
  },
  {
    label: "Agende sua Visita",
    sub: "Conheça a escola pessoalmente",
    href: "/visita",
    icon: "calendar",
    highlight: false,
  },
  {
    label: "Curso de Piercing Presencial",
    sub: "Aprenda a aplicar com segurança",
    href: "/curso-piercing-presencial",
    icon: "ring",
    highlight: false,
  },
  {
    label: "Curso Online de Tatuagem",
    sub: "Aprenda no seu ritmo, de onde estiver",
    href: "/formacao-de-tatuadores-online",
    icon: "online",
    highlight: false,
  },
  {
    label: "Fale Conosco",
    sub: "Atendimento via WhatsApp",
    href: "https://api.whatsapp.com/send?phone=5511941721536&text=Ol%C3%A1!%20Gostaria%20de%20saber%20mais%20sobre%20os%20cursos%20da%20Projeto%20Tattoo",
    icon: "whatsapp",
    highlight: false,
    external: true,
  },
];
---

<Layout
  title="Links | Projeto Tattoo"
  description="Todos os links da Projeto Tattoo — cursos presenciais e online de tatuagem e piercing em São Paulo."
>
  <main class="linktree">
    <div class="bg-glow"></div>
    <div class="bg-lines"></div>

    <div class="container">
      <!-- Logo -->
      <header class="header">
        <div class="logo-wrap">
          <img
            src="/images/projeto-tattoo-logo-dourado.webp"
            alt="Projeto Tattoo"
            class="logo"
            width="140"
            height="140"
          />
        </div>
        <p class="tagline">13 anos formando tatuadores profissionais</p>
        <div class="divider">
          <span class="divider-line"></span>
          <span class="divider-diamond"></span>
          <span class="divider-line"></span>
        </div>
      </header>

      <!-- Links -->
      <nav class="links-list">
        {links.map((link, i) => (
          <a
            href={link.href}
            class={`link-card ${link.highlight ? 'link-card--highlight' : ''}`}
            target={link.external ? '_blank' : '_self'}
            rel={link.external ? 'noopener noreferrer' : undefined}
            style={`--delay: ${i * 0.1}s`}
          >
            <span class="link-icon">
              {link.icon === 'needle' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 4L4 20M14 4l6 6M4 14l6 6"/>
                  <circle cx="6" cy="18" r="2"/>
                </svg>
              )}
              {link.icon === 'calendar' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <path d="M16 2v4M8 2v4M3 10h18"/>
                  <circle cx="12" cy="16" r="1.5" fill="currentColor"/>
                </svg>
              )}
              {link.icon === 'ring' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="12" cy="12" r="9"/>
                  <circle cx="12" cy="12" r="4"/>
                  <path d="M12 3v2M12 19v2M3 12h2M19 12h2"/>
                </svg>
              )}
              {link.icon === 'online' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <rect x="2" y="3" width="20" height="14" rx="2"/>
                  <path d="M8 21h8M12 17v4"/>
                  <path d="M10 10l2.5 2.5L16 8"/>
                </svg>
              )}
              {link.icon === 'whatsapp' && (
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              )}
            </span>
            <span class="link-text">
              <span class="link-label">{link.label}</span>
              <span class="link-sub">{link.sub}</span>
            </span>
            <span class="link-arrow">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 8h10M9 4l4 4-4 4"/>
              </svg>
            </span>
          </a>
        ))}
      </nav>

      <footer class="footer">
        <p>© {new Date().getFullYear()} Projeto Tattoo · São Paulo</p>
      </footer>
    </div>
  </main>
</Layout>

<style>
  .linktree {
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 3rem 1.25rem 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Background atmosphere */
  .bg-glow {
    position: fixed;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(201, 169, 98, 0.12) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .bg-lines {
    position: fixed;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 79px,
        rgba(255,255,255,0.018) 79px,
        rgba(255,255,255,0.018) 80px
      );
    pointer-events: none;
    z-index: 0;
  }

  .container {
    width: 100%;
    max-width: 480px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  .header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.7s ease-out both;
  }

  .logo-wrap {
    position: relative;
    margin-bottom: 1rem;
  }

  .logo-wrap::after {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(201, 169, 98, 0.2) 0%, transparent 70%);
    animation: logoGlow 3s ease-in-out infinite alternate;
  }

  @keyframes logoGlow {
    from { opacity: 0.6; transform: scale(0.95); }
    to   { opacity: 1;   transform: scale(1.05); }
  }

  .logo {
    width: 110px;
    height: 110px;
    object-fit: contain;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 24px rgba(201, 169, 98, 0.35));
  }

  .tagline {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-dim);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    max-width: 220px;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201, 169, 98, 0.4));
  }

  .divider-line:last-child {
    background: linear-gradient(to left, transparent, rgba(201, 169, 98, 0.4));
  }

  .divider-diamond {
    width: 6px;
    height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(201, 169, 98, 0.6);
  }

  /* Link cards */
  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: var(--white);
    transition: background 0.25s, border-color 0.25s, transform 0.2s;
    animation: fadeInUp 0.6s ease-out both;
    animation-delay: var(--delay);
    -webkit-tap-highlight-color: transparent;
  }

  .link-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .link-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(201, 169, 98, 0.35);
    transform: translateY(-2px);
  }

  .link-card:hover::before {
    opacity: 1;
  }

  .link-card:active {
    transform: translateY(0) scale(0.98);
  }

  /* Highlighted card */
  .link-card--highlight {
    background: rgba(201, 169, 98, 0.1);
    border-color: rgba(201, 169, 98, 0.4);
  }

  .link-card--highlight::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .link-card--highlight:hover {
    background: rgba(201, 169, 98, 0.15);
    border-color: rgba(201, 169, 98, 0.6);
  }

  /* Icon */
  .link-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(201, 169, 98, 0.12);
    border: 1px solid rgba(201, 169, 98, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--gold);
    transition: background 0.25s, border-color 0.25s;
  }

  .link-icon svg {
    width: 20px;
    height: 20px;
  }

  .link-card:hover .link-icon {
    background: rgba(201, 169, 98, 0.2);
    border-color: rgba(201, 169, 98, 0.4);
  }

  /* Text */
  .link-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .link-label {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: var(--white);
    transition: color 0.25s;
  }

  .link-card:hover .link-label {
    color: #fff;
  }

  .link-card--highlight .link-label {
    color: var(--gold-light);
  }

  .link-sub {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--white-dim);
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Arrow */
  .link-arrow {
    color: rgba(255, 255, 255, 0.25);
    flex-shrink: 0;
    transition: color 0.25s, transform 0.25s;
  }

  .link-arrow svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .link-card:hover .link-arrow {
    color: var(--gold);
    transform: translateX(3px);
  }

  /* Footer */
  .footer {
    margin-top: 2.5rem;
    text-align: center;
    animation: fadeInUp 0.6s ease-out 0.6s both;
  }

  .footer p {
    font-size: 0.72rem;
    color: rgba(160, 160, 160, 0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
